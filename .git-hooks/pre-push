#!/bin/bash

# Bloquear pushes directos a main y dev
while read local_ref local_sha remote_ref remote_sha
do
  if [[ "$remote_ref" == *"refs/heads/main"* ]] || [[ "$remote_ref" == *"refs/heads/dev"* ]]; then
    echo "==========================================================="
    echo "❌ ERROR FATAL: BLOQUEO POR REGLA 12 (global-context.md) ❌"
    echo "==========================================================="
    echo "Está terminantemente prohibido hacer push directo a 'main' o 'dev'."
    echo "Debes empujar tu rama de feature o refactor y abrir un PR."
    echo "==========================================================="
    exit 1
  fi
done

exit 0
