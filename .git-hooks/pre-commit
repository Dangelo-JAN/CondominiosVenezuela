#!/bin/bash

# Bloquear commits directos en main y dev
branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch" = "main" ] || [ "$branch" = "dev" ]; then
  echo "==========================================================="
  echo "❌ ERROR FATAL: BLOQUEO POR REGLA 12 (global-context.md) ❌"
  echo "==========================================================="
  echo "Está terminantemente prohibido hacer commits en '$branch'."
  echo "Debes cambiar a una rama propia a partir de 'dev'."
  echo "==========================================================="
  exit 1
fi

exit 0
